# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# Google OAuth (Get from https://console.cloud.google.com)
# Follow GOOGLE_OAUTH_SETUP.md for setup instructions
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Practo API (Optional - for Part 3)
PRACTO_API_KEY="YOUR_PRACTO_API_KEY"
PRACTO_API_SECRET="YOUR_PRACTO_API_SECRET"
PRACTO_WEBHOOK_SECRET="YOUR_PRACTO_WEBHOOK_SECRET"
PRACTO_CLINIC_ID="YOUR_CLINIC_ID"
PRACTO_API_URL="https://api.practo.com/v1"

# Payment Gateway (Optional)
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET"

# Email (Optional - SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="your-email@example.com"
SENDGRID_FROM_NAME="Your Clinic Name"

# Email (Alternative - Gmail for development)
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASS="your-app-specific-password"

# SMS (Optional - Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
